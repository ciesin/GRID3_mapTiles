# =============================================================================
# Environment configuration for GRID3 PMTiles map
# =============================================================================
#
# Only ONE variable is required per environment. All archive paths and
# attribution live in src/sources.ts and are version-controlled there.
#
# BUCKET CHAIN:
#   .env.development  →  wrangler.toml default env       →  ciesin-dev
#   .env.production   →  wrangler.toml [env.production]  →  ciesin-prod
#
# LOCAL USAGE:
#   Copy to .env.development or .env.production (both are git-ignored).
#
# CLOUDFLARE PAGES CI:
#   Set VITE_CLOUDFLARE_WORKER_URL in Pages dashboard under
#   Settings → Environment Variables:
#     Preview    = https://dev-tileworker.ciesin.app
#     Production = https://prod-tileworker.ciesin.app
#
# R2 FOLDER STRUCTURE (documented in src/sources.ts):
#   {bucket}/tiles/
#     protomaps/base.pmtiles
#     overture/buildings.pmtiles
#     mapterhorn/terrain.pmtiles
#     grid3/{iso}/{dataset_version}.pmtiles
#
# WORKER DEPLOY COMMANDS:
#   Dev:  wrangler deploy
#   Prod: wrangler deploy --env production
# =============================================================================

# REQUIRED: Cloudflare Worker URL for this environment.
VITE_CLOUDFLARE_WORKER_URL=https://dev-tileworker.ciesin.app

# =============================================================================
# Optional: self-hosted sprites and fonts (defaults to Protomaps CDN)
# Upload Protomaps assets to tiles/assets/ in R2 to remove CDN dependency.
# =============================================================================

# VITE_SPRITE_BASE_URL=https://prod-tileworker.ciesin.app/tiles/assets/sprites/v4
# VITE_GLYPHS_URL=https://prod-tileworker.ciesin.app/tiles/assets/fonts/{fontstack}/{range}.pbf
