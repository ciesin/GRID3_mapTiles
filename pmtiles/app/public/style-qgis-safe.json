{
  "version": 8,
  "sources": {
    "protomaps": {
      "type": "vector",
      "attribution": "<a href=\"https://github.com/protomaps/basemaps\">Protomaps</a> © <a href=\"https://openstreetmap.org\">OpenStreetMap Contributors</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/base/{z}/{x}/{y}.mvt"],
      "maxzoom": 15
    },
    "overture": {
      "type": "vector",
      "attribution": "<a href=\"https://overturemaps.org\">Overture Maps Foundation</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/overture/buildings/{z}/{x}/{y}.mvt"],
      "maxzoom": 14
    },
    "terrain": {
      "type": "raster",
      "attribution": "<a href=\"https://mapterhorn.com/attribution\">© Mapterhorn</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/terrain/{z}/{x}/{y}.webp"],
      "maxzoom": 12,
      "tileSize": 256
    },
    "grid3": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/{z}/{x}/{y}.mvt"],
      "maxzoom": 15
    },
    "grid3_cod_provinces": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/cod/GRID3_COD_provinces_v8_0/{z}/{x}/{y}.mvt"],
      "maxzoom": 7
    },
    "grid3_cod_provinces_centroids": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/cod/GRID3_COD_provinces_v8_0_centroids/{z}/{x}/{y}.mvt"],
      "maxzoom": 16
    },
    "grid3_cod_antenne": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/cod/GRID3_COD_antenne_v8_0/{z}/{x}/{y}.mvt"],
      "maxzoom": 8
    },
    "grid3_cod_antenne_centroids": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/cod/GRID3_COD_antenne_v8_0_centroids/{z}/{x}/{y}.mvt"],
      "maxzoom": 16
    },
    "grid3_cod_health_zones": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/cod/GRID3_COD_health_zones_v8_0/{z}/{x}/{y}.mvt"],
      "maxzoom": 8
    },
    "grid3_cod_health_zones_centroids": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/cod/GRID3_COD_health_zones_v8_0_centroids/{z}/{x}/{y}.mvt"],
      "maxzoom": 2
    },
    "grid3_cod_health_areas": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/cod/GRID3_COD_health_areas_v8_0/{z}/{x}/{y}.mvt"],
      "maxzoom": 8
    },
    "grid3_cod_health_areas_centroids": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/cod/GRID3_COD_health_areas_v8_0_centroids/{z}/{x}/{y}.mvt"],
      "maxzoom": 4
    },
    "grid3_cod_health_facilities": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/cod/GRID3_COD_health_facilities_v8_0/{z}/{x}/{y}.mvt"],
      "maxzoom": 8
    },
    "grid3_cod_settlement_names": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/cod/GRID3_COD_settlement_names_v8_0/{z}/{x}/{y}.mvt"],
      "maxzoom": 8
    },
    "grid3_nga_settlement_extents": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/nga/GRID3_NGA_settlement_extents_v3_0/{z}/{x}/{y}.mvt"],
      "maxzoom": 14
    },
    "grid3_nga_settlement_blocks": {
      "type": "vector",
      "attribution": "<a href=\"https://ciesin.columbia.edu/\">© CIESIN Columbia University</a>",
      "tiles": ["https://dev-tileworker.ciesin.app/tiles/grid3/nga/GRID3_NGA_settlement_extents_v4_0/{z}/{x}/{y}.mvt"],
      "maxzoom": 14
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#e2dfda" }
    },
    {
      "id": "earth",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "earth",
      "filter": ["==", "$type", "Polygon"],
      "paint": { "fill-color": "#e2dfda" }
    },
    {
      "id": "landcover",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landcover",
      "paint": { "fill-color": "#c4e7d2", "fill-opacity": 0.5 }
    },
    {
      "id": "landuse_park",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["in", "kind", "national_park", "park", "cemetery", "protected_area", "nature_reserve", "forest", "golf_course"],
      "paint": { "fill-color": "#88D18A", "fill-opacity": 0.6 }
    },
    {
      "id": "landuse_hospital",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["==", "kind", "hospital"],
      "paint": { "fill-color": "#fde1e4" }
    },
    {
      "id": "landuse_school",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "landuse",
      "filter": ["in", "kind", "school", "university", "college"],
      "paint": { "fill-color": "#F8E08E" }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "protomaps",
      "source-layer": "water",
      "filter": ["==", "$type", "Polygon"],
      "paint": { "fill-color": "#A4DBE8" }
    },
    {
      "id": "water_river",
      "type": "line",
      "source": "protomaps",
      "source-layer": "water",
      "minzoom": 9,
      "filter": ["in", "kind", "river"],
      "paint": { "line-color": "#9ADBE8", "line-width": 2 }
    },
    {
      "id": "water_stream",
      "type": "line",
      "source": "protomaps",
      "source-layer": "water",
      "minzoom": 12,
      "filter": ["in", "kind", "stream"],
      "paint": { "line-color": "#A4DBE8", "line-width": 1 }
    },
    {
      "id": "settlement-extents",
      "type": "fill",
      "source": "grid3",
      "source-layer": "settlement-extents",
      "minzoom": 7,
      "paint": { "fill-color": "#CAA2DD", "fill-opacity": 0.5 }
    },
    {
      "id": "settlement-extents-outline",
      "type": "line",
      "source": "grid3",
      "source-layer": "settlement-extents",
      "minzoom": 7,
      "paint": { "line-color": "#B580D1", "line-width": 0.5, "line-opacity": 0.6 }
    },
    {
      "id": "nga-settlement-extents",
      "type": "fill",
      "source": "grid3_nga_settlement_extents",
      "source-layer": "settlement-extents",
      "minzoom": 7,
      "paint": { "fill-color": "#CAA2DD", "fill-opacity": 0.5 }
    },
    {
      "id": "nga-settlement-extents-outline",
      "type": "line",
      "source": "grid3_nga_settlement_extents",
      "source-layer": "settlement-extents",
      "minzoom": 7,
      "paint": { "line-color": "#B580D1", "line-width": 0.5, "line-opacity": 0.6 }
    },
    {
      "id": "nga-settlement-blocks",
      "type": "fill",
      "source": "grid3_nga_settlement_blocks",
      "source-layer": "settlement-extents",
      "minzoom": 10,
      "paint": { "fill-color": "#9B59B6", "fill-opacity": 0.35 }
    },
    {
      "id": "cod-health-zones",
      "type": "fill",
      "source": "grid3_cod_health_zones",
      "source-layer": "health-zones",
      "minzoom": 6,
      "paint": { "fill-color": "#FF6B6B", "fill-opacity": 0.08 }
    },
    {
      "id": "cod-health-zones-boundary",
      "type": "line",
      "source": "grid3_cod_health_zones",
      "source-layer": "health-zones",
      "minzoom": 6,
      "paint": { "line-color": "#FF6B6B", "line-width": 1.5, "line-opacity": 0.7 }
    },
    {
      "id": "cod-health-areas",
      "type": "fill",
      "source": "grid3_cod_health_areas",
      "source-layer": "health-areas",
      "minzoom": 9,
      "paint": { "fill-color": "#4ECDC4", "fill-opacity": 0.08 }
    },
    {
      "id": "cod-health-areas-boundary",
      "type": "line",
      "source": "grid3_cod_health_areas",
      "source-layer": "health-areas",
      "minzoom": 9,
      "paint": { "line-color": "#4ECDC4", "line-width": 1, "line-opacity": 0.6 }
    },
    {
      "id": "cod-antenne",
      "type": "fill",
      "source": "grid3_cod_antenne",
      "source-layer": "antenne",
      "minzoom": 8,
      "paint": { "fill-color": "#F39C12", "fill-opacity": 0.12 }
    },
    {
      "id": "cod-antenne-boundary",
      "type": "line",
      "source": "grid3_cod_antenne",
      "source-layer": "antenne",
      "minzoom": 8,
      "paint": { "line-color": "#F39C12", "line-width": 1, "line-opacity": 0.6 }
    },
    {
      "id": "cod-provinces",
      "type": "fill",
      "source": "grid3_cod_provinces",
      "source-layer": "provinces",
      "minzoom": 3,
      "paint": { "fill-color": "#2980B9", "fill-opacity": 0.06 }
    },
    {
      "id": "cod-provinces-boundary",
      "type": "line",
      "source": "grid3_cod_provinces",
      "source-layer": "provinces",
      "minzoom": 3,
      "paint": { "line-color": "#2980B9", "line-width": 1.5, "line-opacity": 0.7 }
    },
    {
      "id": "roads_other",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["in", "kind", "other", "path"],
      "paint": { "line-color": "#d5d5d5", "line-width": 1 }
    },
    {
      "id": "roads_minor",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["==", "kind", "minor_road"],
      "paint": { "line-color": "#ffffff", "line-width": 2 }
    },
    {
      "id": "roads_major",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["==", "kind", "major_road"],
      "paint": { "line-color": "#ffffff", "line-width": 3 }
    },
    {
      "id": "roads_highway",
      "type": "line",
      "source": "protomaps",
      "source-layer": "roads",
      "filter": ["==", "kind", "highway"],
      "paint": { "line-color": "#ffffff", "line-width": 4 }
    },
    {
      "id": "boundaries_country",
      "type": "line",
      "source": "protomaps",
      "source-layer": "boundaries",
      "filter": ["<=", "kind_detail", 2],
      "paint": { "line-color": "#adadad", "line-width": 1.2, "line-dasharray": [3, 2] }
    },
    {
      "id": "buildings-flat",
      "type": "fill",
      "source": "overture",
      "source-layer": "building",
      "minzoom": 13,
      "paint": { "fill-color": "#A2ACAB", "fill-opacity": 0.5 }
    },
    {
      "id": "building-outlines",
      "type": "line",
      "source": "overture",
      "source-layer": "building",
      "minzoom": 13,
      "paint": { "line-color": "#8897A0", "line-width": 0.5, "line-opacity": 0.5 }
    },
    {
      "id": "cod-health-facilities",
      "type": "circle",
      "source": "grid3_cod_health_facilities",
      "source-layer": "health-facilities",
      "minzoom": 9,
      "paint": {
        "circle-color": "#D32F2F",
        "circle-radius": 4,
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 1
      }
    },
    {
      "id": "cod-antenne-centroids",
      "type": "circle",
      "source": "grid3_cod_antenne_centroids",
      "source-layer": "antenne-centroids",
      "minzoom": 9,
      "paint": {
        "circle-color": "#F39C12",
        "circle-radius": 4,
        "circle-stroke-color": "#ffffff",
        "circle-stroke-width": 1
      }
    },
    {
      "id": "places_locality",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", "kind", "locality"],
      "layout": {
        "text-font": ["Noto Sans Regular"],
        "text-field": ["get", "name"],
        "text-size": 12
      },
      "paint": {
        "text-color": "#263238",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "places_region",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", "kind", "region"],
      "layout": {
        "text-font": ["Noto Sans Bold"],
        "text-field": ["get", "name"],
        "text-size": 14,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#263238",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "places_country",
      "type": "symbol",
      "source": "protomaps",
      "source-layer": "places",
      "filter": ["==", "kind", "country"],
      "layout": {
        "text-font": ["Noto Sans Bold"],
        "text-field": ["get", "name"],
        "text-size": 16,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#263238",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "cod-settlement-names",
      "type": "symbol",
      "source": "grid3_cod_settlement_names",
      "source-layer": "settlement-names",
      "minzoom": 11,
      "layout": {
        "text-font": ["Noto Sans Regular"],
        "text-field": ["get", "name"],
        "text-size": 10
      },
      "paint": {
        "text-color": "#4A148C",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "cod-health-facilities-label",
      "type": "symbol",
      "source": "grid3_cod_health_facilities",
      "source-layer": "health-facilities",
      "minzoom": 12,
      "layout": {
        "text-font": ["Noto Sans Regular"],
        "text-field": ["get", "name"],
        "text-size": 9,
        "text-offset": [0, 1.2]
      },
      "paint": {
        "text-color": "#D32F2F",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "cod-health-areas-label",
      "type": "symbol",
      "source": "grid3_cod_health_areas_centroids",
      "source-layer": "health-areas-centroids",
      "minzoom": 10,
      "layout": {
        "text-font": ["Noto Sans Bold"],
        "text-field": ["get", "nom"],
        "text-size": 11,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#00796B",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      }
    },
    {
      "id": "cod-health-zones-label",
      "type": "symbol",
      "source": "grid3_cod_health_zones_centroids",
      "source-layer": "health-zones-centroids",
      "minzoom": 8,
      "layout": {
        "text-font": ["Noto Sans Bold"],
        "text-field": ["get", "nom"],
        "text-size": 12,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#C62828",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "cod-provinces-label",
      "type": "symbol",
      "source": "grid3_cod_provinces_centroids",
      "source-layer": "provinces-centroids",
      "minzoom": 4,
      "layout": {
        "text-font": ["Noto Sans Bold"],
        "text-field": ["get", "name"],
        "text-size": 14,
        "text-transform": "uppercase"
      },
      "paint": {
        "text-color": "#1565C0",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      }
    }
  ],
  "glyphs": "https://protomaps.github.io/basemaps-assets/fonts/{fontstack}/{range}.pbf"
}
