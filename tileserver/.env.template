CLOUDFLARE_TUNNEL_TOKEN=

# AWS S3-compatible credentials for Cloudflare R2
# Get these from Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# export AWS_ACCESS_KEY_ID=
# export AWS_SECRET_ACCESS_KEY=

# Cloudflare R2 endpoint
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Cloudflare Account ID (found in R2 dashboard)
R2_ACCOUNT_ID=

# R2 bucket name
R2_BUCKET_NAME=

# Region (typically "auto" for R2)
R2_REGION=auto

# Use environment variables for authentication (true/false)
# Set to false to use access key/secret directly, true for env vars
R2_ENV_AUTH=false

# ACL for uploaded objects (private, public-read, etc.)
R2_ACL=public-read