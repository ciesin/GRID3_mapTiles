{
  "comment": "zoom filter lookup table. Named keys = tippecanoe zoom_filter_windows (used by tippecanoe.py modifiers via filter_key). Maxzoom is omitted from named entries; the layer's own maxzoom is filled in at build time.",
  "comment2": "to add a new zoom-stepped filter for settlement names, add a key to tile_layer_steps.json, then reference it with modifier: <your_key> in the YAML layer entry",
  
  "roads": {
    "zoom_filter_windows": [
      { "minzoom":  5, "filter": [ "in", "class", "motorway", "trunk" ] },
      { "minzoom":  6, "filter": [ "==", "class", "primary" ] },
      { "minzoom":  7, "filter": [ "==", "class", "secondary" ] },
      { "minzoom":  10, "filter": [ "==", "class", "tertiary" ] },
      { "minzoom":  11, "filter": [ "in", "class", "unclassified", "track", "unknown", "residential" ] },
      { "minzoom": 11, "filter": [ "in", "class", "path", "footway", "bridleway", "cycleway", "pedestrian", "living_street", "water track" ] },
      { "minzoom": 13, "filter": [ "in", "class", "service", "steps" ] }
    ]
  },

  "settlement_extents_type": {
    "zoom_filter_windows": [
      { "minzoom":  7, "filter": [ "==", "type", "Built-up Area" ] },
      { "minzoom": 10, "filter": [ "==", "type", "Small Settlement Area" ] },
      { "minzoom": 12, "filter": [ "==", "type", "Hamlet" ] }
    ]
  },

  "settlement_extents_extent_type": {
    "zoom_filter_windows": [
      { "minzoom":  7, "filter": [ "==", "extent_type", "Built-up Area" ] },
      { "minzoom": 10, "filter": [ "==", "extent_type", "Small Settlement Area" ] },
      { "minzoom": 12, "filter": [ "==", "extent_type", "Hamlet" ] }
    ]
  },

  "health_facilities_esstype": {
    "zoom_filter_windows": [
      { "minzoom":  7, "filter": [ "in", "esstype", "Bureau Central de la Zone de Santé", "Hôpital Général de Référence" ] },
      { "minzoom":  9, "filter": [ "in", "esstype", "Hôpital", "Centre Hopitalier" ] },
      { "minzoom": 10, "filter": [ "in", "esstype", "Centre Médical", "Centre de Santé de Référence", "Centre de Santé", "Poste de Santé" ] },
      { "minzoom": 13, "filter": [ "in", "esstype", "Clinique", "Polyclinque", "Dispensaire", "Site Soin Communautaire", "Autre" ] }
    ]
  }
}
